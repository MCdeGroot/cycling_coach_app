# Supabase — haal deze op uit je Supabase project dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Intervals.icu OAuth2 — registreer een app via https://intervals.icu/settings (Developer > OAuth Apps)
# Redirect URI: http://localhost:3000/api/intervals/callback (dev)
#               https://your-app.vercel.app/api/intervals/callback (prod)
INTERVALS_CLIENT_ID=your-intervals-client-id
INTERVALS_CLIENT_SECRET=your-intervals-client-secret

# App URL — basis-URL van de app (geen trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
